# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Repo Details
REPO_OWNER=yourusername
REPO_NAME=leetcode-daily

# Telegram (optional - enable with --features telegram)
TELEGRAM_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Discord (optional - enable with --features discord)
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id

# Personal
# Year of birth for age-related calculations
BIRTH_YEAR=1990
# Timezone for date/time operations (e.g., UTC, America/New_York, Asia/Shanghai)
TIMEZONE=UTC

# LeetCode
# GraphQL endpoint for LeetCode API
# For LeetCode.com: https://leetcode.com/graphql/
# For LeetCode CN: https://leetcode.cn/graphql/
LEETCODE_ENDPOINT=https://leetcode.com/graphql/
# LeetCode variant: com for leetcode.com, cn for leetcode.cn
LEETCODE_VARIANT=com

# Running Stats (optional - remote parquet URL or local file)
# URL to a remote parquet file containing running statistics
RUNNING_PARQUET_URL=https://github.com/yourname/run/raw/refs/heads/master/run_page/data.parquet
# Or use local file instead:
# RUNNING_PARQUET_FILE=data/running.parquet

# Wake-up time range (optional, defaults to 3-9)
# Start hour for wake-up detection (24-hour format)
WAKE_UP_START=3
# End hour for wake-up detection (24-hour format)
WAKE_UP_END=9

# Default fallback for history events
# Year to use when calculating historical events without explicit dates
BIRTH_YEAR_FOR_HISTORY=1989
